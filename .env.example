# NirmiqEcho configuration
# Copy this to .env and fill in values

# ── Claude Haiku (optional) ────────────────────────────────────────────
# Only called for commands that don't match any regex pattern (~5% of commands).
# Leave blank to use regex-only mode.
ANTHROPIC_API_KEY=sk-ant-...

# ── Whisper model ─────────────────────────────────────────────────────
# tiny.en  ~82% acc, <1s    |  small.en  ~93%, ~1s
# medium.en ~96% acc, ~2s   |  large-v3  ~98%, ~4s (needs good CPU)
# Default: medium.en
WHISPER_MODEL=medium.en

# ── VAD sensitivity ───────────────────────────────────────────────────
# Lower = catches quieter voices. Raise if lots of false triggers.
# Default: 400 (suits a quiet room)
SPEECH_RMS_THRESHOLD=400

# ── Noise reduction strength ──────────────────────────────────────────
# 0.0 = off, 1.0 = maximum. Default: 0.80
NOISE_REDUCE_STRENGTH=0.80

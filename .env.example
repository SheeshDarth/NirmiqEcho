# NirmiqEcho configuration
# Copy this to .env and fill in values

# ── Claude Haiku (optional) ────────────────────────────────────────────
# Only called for commands that don't match any regex pattern (~5% of commands).
# Leave blank to use regex-only mode.
ANTHROPIC_API_KEY=sk-ant-...

# ── Whisper model ─────────────────────────────────────────────────────
# LEAVE BLANK for auto-detect (recommended):
#   GPU found  → large-v3 float16  (99.5% acc, 1-2s commands)
#   CPU only   → small.en          (97% acc, 1-2s commands, 500MB)
# Set explicitly only to force a specific model on any device:
#   small.en | medium.en | large-v3
WHISPER_MODEL=

# ── Input microphone ─────────────────────────────────────────────────
# LEAVE BLANK for auto-detect: uses the Windows default mic, but if it is
# silent (e.g. idle Bluetooth buds), Echo scans and picks a live mic.
# Set to a device index or name fragment to pin one, e.g.:
#   INPUT_DEVICE=Microphone Array     (laptop's built-in mic)
# Run "python mic_check.py" inside voiceflow_local to list devices.
INPUT_DEVICE=

# ── VAD sensitivity ───────────────────────────────────────────────────
# Lower = catches quieter voices. Raise if lots of false triggers.
# Default: 400 (suits a quiet room)
SPEECH_RMS_THRESHOLD=400

# ── Noise reduction strength ──────────────────────────────────────────
# 0.0 = off, 1.0 = maximum.
# 0.65 is conservative — removes room noise without touching the voice.
# Raise to 0.80+ only if in a very noisy environment; lower reduces latency.
NOISE_REDUCE_STRENGTH=0.65
